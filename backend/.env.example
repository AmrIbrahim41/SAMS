# انسخ الملف ده لـ .env وعدّل القيم
SECRET_KEY=change-this-to-a-long-random-string
DEBUG=True
# محلي: sqlite ينفع. على الـ VPS استخدم postgres
DATABASE_URL=
# لو postgres:
# DB_NAME=sams
# DB_USER=sams
# DB_PASSWORD=your-password
# DB_HOST=127.0.0.1
# DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:5173

# بيانات السوبر يوزر لأمر: python manage.py seed_admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sams.local
ADMIN_PASSWORD=SamsAdmin#2026
